<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-key brand-icon"></i>
                <h2>Mot de passe oublié ?</h2>
                <p>Entrez votre adresse email et nous vous enverrons un code pour réinitialiser votre mot de passe.</p>
                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-envelope"></i>
                        <span>Nous vous enverrons un code par email</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-clock"></i>
                        <span>Code valable 15 minutes</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Réinitialisez en toute sécurité</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Mot de passe oublié</h2>
                <p class="auth-subtitle">Entrez votre email pour recevoir un code</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success[0] %></span>
                    </div>
                <% } %>

                <form action="/forgot-password" method="POST">
                    <div class="form-group">
                        <label>Adresse e-mail</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope"></i>
                            <input type="email" name="email" placeholder="exemple@email.com" required>
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-paper-plane"></i>
                        Envoyer le code
                    </button>
                </form>

                <div class="auth-footer">
                    <a href="/login">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
