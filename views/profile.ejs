<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'profile' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'profile' }) %>

        <main class="feed">

            <% if (success && success.length > 0) { %>
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span><%= success[0] %></span>
                </div>
            <% } %>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- En-tête du profil -->
            <div class="card profile-header" style="position:relative;">
                <% if (isOwnProfile) { %>
                <a href="/settings" class="ajax-link" title="Paramètres" style="position:absolute;top:14px;right:14px;z-index:10;width:36px;height:36px;border-radius:50%;background:rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;text-decoration:none;backdrop-filter:blur(4px);transition:background .2s;" onmouseover="this.style.background='rgba(0,0,0,.55)'" onmouseout="this.style.background='rgba(0,0,0,.35)'">
                    <i class="fa-solid fa-gear"></i>
                </a>
                <% } %>
                <div class="profile-cover" id="profileCoverBg" style="<%= profileUser.profileCover ? 'background-image:url(' + profileUser.profileCover + ');background-size:cover;background-position:center;background-color:transparent;' : '' %>">
                    <% if (isOwnProfile) { %>
                    <button onclick="openCoverPicker()" id="coverCameraBtn" title="Changer le fond">
                        <i class="fa-solid fa-camera"></i>
                    </button>
                    <% } %>
                </div>
                <div class="profile-header-content">
                    <!-- ===== AVATAR AVEC EFFET ===== -->
                    <div class="<%= profileUser.profileEffect ? 'effect-' + profileUser.profileEffect : '' %>" style="display:inline-block; position:relative;">
                        <img src="<%= profileUser.photoProfil %>"
                             class="profile-avatar<%= profileUser.profileFrame ? ' frame-' + profileUser.profileFrame : '' %>"
                             alt="">
                    </div>
                    <div class="profile-name">
                        <%= profileUser.nom %>
                        <%- include('partials/badges', { badges: profileUser.badges }) %>
                    </div>
                    <% if (profileUser.profileTitle) {
                        const titleMap = {
                            'Pro':     { key: 'pro',     icon: 'fa-briefcase' },
                            'Expert':  { key: 'expert',  icon: 'fa-graduation-cap' },
                            'VIP':     { key: 'vip',     icon: 'fa-crown' },
                            'Élite':   { key: 'elite',   icon: 'fa-shield-halved' },
                            'Légende': { key: 'legende', icon: 'fa-trophy' }
                        };
                        const tInfo = titleMap[profileUser.profileTitle] || { key: 'pro', icon: 'fa-star' };
                    %>
                    <div class="profile-title-badge badge-title-<%= tInfo.key %>">
                        <i class="fa-solid <%= tInfo.icon %>"></i>
                        <%= profileUser.profileTitle %>
                    </div>
                    <% } %>
                    <% if (profileUser.bio) { %>
                        <div class="profile-bio"><%= profileUser.bio %></div>
                    <% } else { %>
                        <div class="profile-bio" style="opacity:0.5;">Aucune bio renseignée</div>
                    <% } %>

                    <div class="profile-stats">
                        <div class="profile-stat">
                            <strong><%= posts.length %></strong>
                            <span>Publications</span>
                        </div>
                        <div class="profile-stat">
                            <strong><%= profileUser.amis.length %></strong>
                            <span>Amis</span>
                        </div>
                        <div class="profile-stat">
                            <strong id="followersCount"><%= profileUser.followers ? profileUser.followers.length : 0 %></strong>
                            <span>Abonnés</span>
                        </div>
                        <% if (!isOwnProfile) { %>
                            <div class="profile-stat">
                                <strong><%= profileUser.following ? profileUser.following.length : 0 %></strong>
                                <span>Abonnements</span>
                            </div>
                        <% } %>
                    </div>

                    <div style="margin-top:18px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                        <% if (isOwnProfile) { %>
                            <a href="/profile/edit/me" class="btn btn-secondary" style="width:auto; padding:10px 24px;">
                                <i class="fa-solid fa-pen"></i> Modifier le profil
                            </a>
                        <% } else { %>
                            <%# Bouton ami %>
                            <% if (isFriend) { %>
                                <form action="/friends/remove/<%= profileUser._id %>" method="POST" style="margin:0;">
                                    <button type="submit" class="btn btn-secondary" style="width:auto; padding:10px 20px;">
                                        <i class="fa-solid fa-user-check"></i> Amis
                                    </button>
                                </form>
                                <a href="/messages/<%= profileUser._id %>" class="btn" style="width:auto; padding:10px 20px;">
                                    <i class="fa-solid fa-comment"></i> Message
                                </a>
                            <% } else if (requestSent) { %>
                                <form action="/friends/cancel/<%= profileUser._id %>" method="POST" style="margin:0;">
                                    <button type="submit" class="btn btn-secondary" style="width:auto; padding:10px 20px;">
                                        <i class="fa-solid fa-clock"></i> Annuler
                                    </button>
                                </form>
                            <% } else if (requestReceived) { %>
                                <form action="/friends/accept/<%= profileUser._id %>" method="POST" style="margin:0;">
                                    <button type="submit" class="btn" style="width:auto; padding:10px 20px;">
                                        <i class="fa-solid fa-check"></i> Accepter
                                    </button>
                                </form>
                            <% } else { %>
                                <form action="/friends/request/<%= profileUser._id %>" method="POST" style="margin:0;">
                                    <button type="submit" class="btn btn-secondary" style="width:auto; padding:10px 20px;">
                                        <i class="fa-solid fa-user-plus"></i> Ajouter
                                    </button>
                                </form>
                            <% } %>

                            <%# Bouton Suivre — indépendant du système d'amis %>
                            <button id="followBtn"
                                data-id="<%= profileUser._id %>"
                                data-following="<%= isFollowing ? 'true' : 'false' %>"
                                class="btn <%= isFollowing ? 'btn-secondary' : 'btn-primary' %>"
                                style="width:auto; padding:10px 20px;">
                                <% if (isFollowing) { %>
                                    <i class="fa-solid fa-bell-slash"></i> Abonné
                                <% } else { %>
                                    <i class="fa-solid fa-bell"></i> Suivre
                                <% } %>
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (isOwnProfile) { %>
            <div class="card" style="padding:16px 20px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
                <div style="display:flex; gap:20px; flex-wrap:wrap;">
                    <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                        <i class="fa-solid fa-coins" style="font-size:20px; color:#f59e0b;"></i>
                        <span style="font-size:17px; font-weight:700; color:#f59e0b;">
                            <% if (profileUser.role === 'admin') { %>∞<% } else { %><%= profileUser.walletBalance || 0 %><% } %>
                        </span>
                        <span style="font-size:11px; color:var(--text-secondary);"><%= profileUser.role === 'admin' ? 'Illimité' : 'Crédits' %></span>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                        <i class="fa-solid fa-star" style="font-size:20px; color:#8b5cf6;"></i>
                        <span style="font-size:17px; font-weight:700; color:#8b5cf6;"><%= profileUser.xp || 0 %></span>
                        <span style="font-size:11px; color:var(--text-secondary);">XP</span>
                    </div>
                </div>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <a href="/wallet" class="btn btn-secondary" style="width:auto; padding:8px 18px; font-size:13px;">
                        <i class="fa-solid fa-wallet"></i> Portefeuille
                    </a>
                    <a href="/shop" class="btn" style="width:auto; padding:8px 18px; font-size:13px;">
                        <i class="fa-solid fa-store"></i> Boutique
                    </a>
                </div>
            </div>

            <% } %>

            <!-- HISTORIQUE QUÊTES ORACLE -->
            <% if (isOwnProfile) { %>
            <div class="card" style="padding:16px 20px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
                    <i class="fa-solid fa-brain" style="font-size:20px;color:#7c3aed;"></i>
                    <div>
                        <div style="font-size:14px;font-weight:700;">Quêtes Oracle — 7 derniers jours</div>
                        <div style="font-size:12px;color:var(--text-secondary);">Ton historique de missions et streak</div>
                    </div>
                </div>
                <div id="oracleHistoryList" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;">
                    <span style="font-size:12px;color:var(--text-secondary);">Chargement…</span>
                </div>
                <style>
                    .oh-day { display:flex;flex-direction:column;align-items:center;gap:3px;min-width:44px;padding:8px 6px;border-radius:10px;border:1px solid var(--border);font-size:11px;cursor:default;transition:.2s; }
                    .oh-dot { font-size:20px;line-height:1; }
                    .oh-lbl { font-weight:600;color:var(--text-secondary); }
                    .oh-coins { font-size:10px;font-weight:700;color:#f59e0b; }
                    .oh-day-done { background:linear-gradient(135deg,rgba(124,58,237,.08),rgba(79,70,229,.08));border-color:#7c3aed44; }
                    .oh-day-todo { background:rgba(34,197,94,.07);border-color:#22c55e55; }
                    .oh-day-active { background:rgba(245,158,11,.07);border-color:#f59e0b55; }
                    .oh-day-miss { opacity:.45; }
                </style>
            </div>
            <% } %>

            <!-- MA COLLECTION -->
            <% if (isOwnProfile) {
                const now = new Date();
                const activeBadges = (profileUser.badges || []).filter(b => !b.expiresAt || new Date(b.expiresAt) > now);
                const expiredBadges = (profileUser.badges || []).filter(b => b.expiresAt && new Date(b.expiresAt) <= now);
                const hasCollection = activeBadges.length > 0 || expiredBadges.length > 0 || profileUser.profileTitle || profileUser.profileFrame || (profileUser.theme && profileUser.theme !== 'default') || profileUser.profileEffect;
            %>
            <div class="card" style="padding:16px 20px;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
                    <i class="fa-solid fa-box-open" style="font-size:20px;"></i>
                    <div>
                        <div style="font-size:14px;font-weight:700;">Ma Collection</div>
                        <div style="font-size:12px;color:var(--text-secondary);">Tous tes cosmétiques actifs et expirés</div>
                    </div>
                </div>
                <% if (!hasCollection) { %>
                <div style="text-align:center;padding:16px;color:var(--text-secondary);font-size:13px;">
                    <i class="fa-solid fa-box-open" style="font-size:28px;margin-bottom:8px;display:block;opacity:0.4;"></i>
                    Ta collection est vide — visite la <a href="/shop" style="color:var(--primary);">Boutique</a> pour obtenir des cosmétiques !
                </div>
                <% } else { %>
                <div style="display:flex;flex-direction:column;gap:10px;">

                    <% if (profileUser.profileEffect) { %>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);">
                        <i class="fa-solid fa-sparkles" style="font-size:20px;color:var(--primary);"></i>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;">Effet : <span style="text-transform:capitalize;color:var(--primary);">
                                <% if (profileUser.profileEffect === 'sparkle') { %><i class="fa-solid fa-star-shooting"></i> Étincelles<% } %>
                                <% if (profileUser.profileEffect === 'flame') { %><i class="fa-solid fa-fire"></i> Flammes<% } %>
                                <% if (profileUser.profileEffect === 'star') { %><i class="fa-solid fa-star"></i> Étoiles<% } %>
                                <% if (profileUser.profileEffect === 'diamond') { %><i class="fa-solid fa-gem"></i> Diamant<% } %>
                                <% if (profileUser.profileEffect === 'butterfly') { %><i class="fa-solid fa-leaf"></i> Papillons<% } %>
                            </span></div>
                            <div style="font-size:11px;color:var(--text-secondary);">Animation autour de ton avatar</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span style="font-size:11px;background:rgba(16,185,129,0.15);color:#10b981;padding:3px 8px;border-radius:20px;font-weight:600;"><i class="fa-solid fa-check"></i> Actif</span>
                            <button onclick="unequipItem('profileEffect', this)" style="border:none;background:rgba(239,68,68,0.12);color:#ef4444;border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;"><i class="fa-solid fa-xmark"></i> Retirer</button>
                        </div>
                    </div>
                    <% } %>

                    <% if (profileUser.theme && profileUser.theme !== 'default') { %>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);">
                        <i class="fa-solid fa-palette" style="font-size:20px;"></i>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;">Thème : <span style="text-transform:capitalize;color:var(--primary);"><%= profileUser.theme %></span></div>
                            <div style="font-size:11px;color:var(--text-secondary);">Thème actif sur ton profil</div>
                        </div>
                        <span style="font-size:11px;background:rgba(16,185,129,0.15);color:#10b981;padding:3px 8px;border-radius:20px;font-weight:600;"><i class="fa-solid fa-check"></i> Actif</span>
                    </div>
                    <% } %>

                    <% if (profileUser.profileTitle) { %>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);">
                        <i class="fa-solid fa-crown" style="font-size:20px;color:#f59e0b;"></i>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;">Titre : <span style="color:var(--primary);"><%= profileUser.profileTitle %></span></div>
                            <div style="font-size:11px;color:var(--text-secondary);">Affiché sous ton nom de profil</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span style="font-size:11px;background:rgba(16,185,129,0.15);color:#10b981;padding:3px 8px;border-radius:20px;font-weight:600;"><i class="fa-solid fa-check"></i> Actif</span>
                            <button onclick="unequipItem('profileTitle', this)" style="border:none;background:rgba(239,68,68,0.12);color:#ef4444;border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;"><i class="fa-solid fa-xmark"></i> Retirer</button>
                        </div>
                    </div>
                    <% } %>

                    <% if (profileUser.profileFrame) { %>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);">
                        <i class="fa-solid fa-image" style="font-size:20px;color:#6366f1;"></i>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;">Cadre : <span style="text-transform:capitalize;color:var(--primary);"><%= profileUser.profileFrame %></span></div>
                            <div style="font-size:11px;color:var(--text-secondary);">Cadre autour de ta photo de profil</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span style="font-size:11px;background:rgba(16,185,129,0.15);color:#10b981;padding:3px 8px;border-radius:20px;font-weight:600;"><i class="fa-solid fa-check"></i> Actif</span>
                            <button onclick="unequipItem('profileFrame', this)" style="border:none;background:rgba(239,68,68,0.12);color:#ef4444;border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;"><i class="fa-solid fa-xmark"></i> Retirer</button>
                        </div>
                    </div>
                    <% } %>

                    <% if (activeBadges.length > 0) { %>
                    <div>
                        <div style="font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Badges actifs</div>
                        <% activeBadges.forEach(badge => {
                            const badgeIcons = { verifie: '<i class="fa-solid fa-circle-check" style="color:#3b82f6;"></i>', moderateur: '<i class="fa-solid fa-shield" style="color:#8b5cf6;"></i>', fondateur: '<i class="fa-solid fa-trophy" style="color:#f59e0b;"></i>', premium: '<i class="fa-solid fa-gem" style="color:#06b6d4;"></i>', staff: '<i class="fa-solid fa-star" style="color:#f59e0b;"></i>' };
                            const daysLeft = badge.expiresAt ? Math.ceil((new Date(badge.expiresAt) - now) / (1000*60*60*24)) : null;
                        %>
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);margin-bottom:6px;">
                            <span style="font-size:20px;"><%- badgeIcons[badge.type] || '<i class="fa-solid fa-medal"></i>' %></span>
                            <div style="flex:1;">
                                <div style="font-size:13px;font-weight:600;text-transform:capitalize;"><%= badge.type %></div>
                                <% if (badge.expiresAt) { %>
                                <div style="font-size:11px;color:<%= daysLeft <= 3 ? '#f59e0b' : 'var(--text-secondary)' %>;">
                                    <% if (daysLeft <= 3) { %><i class="fa-solid fa-triangle-exclamation" style="color:#f59e0b;"></i> Expire dans <%= daysLeft %> jour<%= daysLeft > 1 ? 's' : '' %> (<%= new Date(badge.expiresAt).toLocaleDateString('fr-FR') %>)<% } else { %>Expire le <%= new Date(badge.expiresAt).toLocaleDateString('fr-FR') %><% } %>
                                </div>
                                <% } else { %>
                                <div style="font-size:11px;color:var(--text-secondary);">Badge permanent</div>
                                <% } %>
                            </div>
                            <span style="font-size:11px;background:rgba(16,185,129,0.15);color:#10b981;padding:3px 8px;border-radius:20px;font-weight:600;">✓ Actif</span>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>

                    <% if (expiredBadges.length > 0) { %>
                    <div>
                        <div style="font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Badges expirés</div>
                        <% expiredBadges.forEach(badge => {
                            const badgeIcons = { verifie: '<i class="fa-solid fa-circle-check" style="color:#3b82f6;"></i>', moderateur: '<i class="fa-solid fa-shield" style="color:#8b5cf6;"></i>', fondateur: '<i class="fa-solid fa-trophy" style="color:#f59e0b;"></i>', premium: '<i class="fa-solid fa-gem" style="color:#06b6d4;"></i>', staff: '<i class="fa-solid fa-star" style="color:#f59e0b;"></i>' };
                        %>
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border);margin-bottom:6px;opacity:0.6;">
                            <span style="font-size:20px;filter:grayscale(1);"><%- badgeIcons[badge.type] || '<i class="fa-solid fa-medal"></i>' %></span>
                            <div style="flex:1;">
                                <div style="font-size:13px;font-weight:600;text-transform:capitalize;"><%= badge.type %></div>
                                <div style="font-size:11px;color:var(--text-secondary);">Expiré le <%= new Date(badge.expiresAt).toLocaleDateString('fr-FR') %></div>
                            </div>
                            <a href="/shop" style="font-size:11px;background:var(--primary);color:#fff;padding:3px 10px;border-radius:20px;font-weight:600;text-decoration:none;">Renouveler</a>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>

                </div>
                <% } %>
            </div>
            <% } %>

            <!-- Publications -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post">
                    <div class="post-header">
                        <!-- ===== AVATAR DU POST AVEC EFFET ===== -->
                        <div class="<%= post.auteur.profileEffect ? 'effect-' + post.auteur.profileEffect : '' %>" style="display:inline-block; position:relative;">
                            <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        </div>
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <% if (post.contenu) { %>
                        <div class="post-content"><%= post.contenu %></div>
                    <% } %>

                    <% if (post.image) { %>
                        <img src="<%= post.image %>" class="post-image" alt="">
                    <% } %>

                    <% if (post.isShared && post.sharedFrom) { %>
                        <div style="border:1.5px solid var(--border); border-radius:12px; padding:14px; margin-top:10px; background:var(--bg-secondary);">
                            <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                                <img src="<%= post.sharedFrom.auteur.photoProfil %>" style="width:30px; height:30px; border-radius:50%; object-fit:cover; border:1px solid var(--border);" alt="">
                                <div>
                                    <div style="font-weight:700; font-size:13px; color:var(--text-primary);"><%= post.sharedFrom.auteur.nom %></div>
                                    <div style="font-size:11px; color:var(--text-muted);">
                                        <%= new Date(post.sharedFrom.createdAt).toLocaleString('fr-FR', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                                    </div>
                                </div>
                            </div>
                            <% if (post.sharedFrom.contenu) { %>
                                <div style="font-size:13.5px; color:var(--text-secondary); line-height:1.5; white-space:pre-wrap;"><%= post.sharedFrom.contenu %></div>
                            <% } %>
                            <% if (post.sharedFrom.image) { %>
                                <img src="<%= post.sharedFrom.image %>" style="width:100%; border-radius:8px; margin-top:8px; max-height:200px; object-fit:cover;" alt="">
                            <% } %>
                        </div>
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">INFORMATIONS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.8;">
                <i class="fa-solid fa-calendar"></i> Membre depuis <%= new Date(profileUser.createdAt).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }) %><br>
                <i class="fa-solid <%= profileUser.enLigne ? 'fa-circle' : 'fa-circle-o' %>" style="color: <%= profileUser.enLigne ? '#16a34a' : '#94a3b8' %>"></i>
                <%= profileUser.enLigne ? 'En ligne' : 'Hors ligne' %>
            </p>
        </aside>
    </div>

    <script src="/js/feed.js?v=2"></script>
    <script src="/js/oracle.js?v=4"></script>
    <script>
        // =============================================
        // BOUTON SUIVRE
        // =============================================
        const followBtn = document.getElementById('followBtn')
        if (followBtn) {
            followBtn.addEventListener('click', async () => {
                const id = followBtn.dataset.id
                const isFollowing = followBtn.dataset.following === 'true'
                followBtn.disabled = true
                followBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'

                const res = await fetch(`/profile/${id}/${isFollowing ? 'unfollow' : 'follow'}`, { method: 'POST' })
                const data = await res.json()
                followBtn.disabled = false

                if (data.success) {
                    const nowFollowing = data.following
                    followBtn.dataset.following = nowFollowing ? 'true' : 'false'
                    followBtn.className = `btn ${nowFollowing ? 'btn-secondary' : 'btn-primary'}`
                    followBtn.style.cssText = 'width:auto; padding:10px 20px;'
                    followBtn.innerHTML = nowFollowing
                        ? '<i class="fa-solid fa-bell-slash"></i> Abonné'
                        : '<i class="fa-solid fa-bell"></i> Suivre'
                    const counter = document.getElementById('followersCount')
                    if (counter && data.count !== undefined) counter.textContent = data.count
                }
            })
        }

        function toggleComments(postId) {
            const el = document.getElementById('comments-' + postId)
            el.style.display = el.style.display === 'none' ? 'block' : 'none'
        }

        async function unequipItem(field, btn) {
            btn.disabled = true
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'
            try {
                const res = await fetch('/api/shop/unequip', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ field })
                })
                const data = await res.json()
                if (data.success) {
                    const row = btn.closest('div[style*="border-radius:10px"]')
                    if (row) {
                        row.style.transition = 'opacity 0.3s'
                        row.style.opacity = '0'
                        setTimeout(() => row.remove(), 300)
                    }
                    location.reload()
                } else {
                    btn.disabled = false
                    btn.innerHTML = '<i class="fa-solid fa-xmark"></i> Retirer'
                }
            } catch(e) {
                btn.disabled = false
                btn.innerHTML = '<i class="fa-solid fa-xmark"></i> Retirer'
            }
        }

        // ===== COVER PICKER =====
        const COVER_IMAGES = [
            { url: 'https://picsum.photos/id/237/800/300', label: 'Chien', cat: '🐾 Animaux' },
            { url: 'https://picsum.photos/id/582/800/300', label: 'Chat', cat: '🐾 Animaux' },
            { url: 'https://picsum.photos/id/593/800/300', label: 'Chien 2', cat: '🐾 Animaux' },
            { url: 'https://picsum.photos/id/169/800/300', label: 'Cheval', cat: '🐾 Animaux' },
            { url: 'https://picsum.photos/id/582/800/300', label: 'Animal', cat: '🐾 Animaux' },
            { url: 'https://picsum.photos/id/783/800/300', label: 'Personnes', cat: '👤 Personnes' },
            { url: 'https://picsum.photos/id/1074/800/300', label: 'Portrait', cat: '👤 Personnes' },
            { url: 'https://picsum.photos/id/1056/800/300', label: 'Voyage', cat: '👤 Personnes' },
            { url: 'https://picsum.photos/id/15/800/300', label: 'Montagne', cat: '🌿 Nature' },
            { url: 'https://picsum.photos/id/29/800/300', label: 'Forêt', cat: '🌿 Nature' },
            { url: 'https://picsum.photos/id/10/800/300', label: 'Fleurs', cat: '🌿 Nature' },
            { url: 'https://picsum.photos/id/547/800/300', label: 'Plage', cat: '🌿 Nature' },
            { url: 'https://picsum.photos/id/164/800/300', label: 'Ville', cat: '🏙️ Villes' },
            { url: 'https://picsum.photos/id/325/800/300', label: 'Nuit', cat: '🏙️ Villes' },
            { url: 'https://picsum.photos/id/358/800/300', label: 'Architecture', cat: '🏙️ Villes' },
            { url: 'https://picsum.photos/id/1016/800/300', label: 'Espace', cat: '✨ Abstrait' },
            { url: 'https://picsum.photos/id/1022/800/300', label: 'Cosmos', cat: '✨ Abstrait' },
            { url: 'https://picsum.photos/id/1076/800/300', label: 'Lumières', cat: '✨ Abstrait' },
        ]

        function buildCoverPicker() {
            const modal = document.getElementById('coverPickerModal')
            if (!modal || modal.dataset.built) return
            modal.dataset.built = '1'
            const sheet = modal.querySelector('.cover-picker-sheet')
            const cats = [...new Set(COVER_IMAGES.map(i => i.cat))]
            let html = ''
            cats.forEach(cat => {
                html += `<div class="cover-cat-label">${cat}</div><div class="cover-grid">`
                COVER_IMAGES.filter(i => i.cat === cat).forEach(img => {
                    html += `<img src="${img.url}" class="cover-thumb" loading="lazy" alt="${img.label}" onclick="selectCover('${img.url}', this)">`
                })
                html += '</div>'
            })
            sheet.insertAdjacentHTML('beforeend', html)
        }

        async function selectCover(url, el) {
            document.querySelectorAll('.cover-thumb').forEach(t => t.classList.remove('selected'))
            el.classList.add('selected')
            try {
                const res = await fetch('/api/profile/cover', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ coverUrl: url })
                })
                const data = await res.json()
                if (data.success) {
                    const bg = document.getElementById('profileCoverBg')
                    if (bg) {
                        bg.style.backgroundImage = `url(${url})`
                        bg.style.backgroundSize = 'cover'
                        bg.style.backgroundPosition = 'center'
                        bg.style.backgroundColor = 'transparent'
                    }
                    setTimeout(() => { document.getElementById('coverPickerModal').style.display = 'none' }, 400)
                }
            } catch(e) {
                el.classList.remove('selected')
            }
        }

        function openCoverPicker() {
            buildCoverPicker()
            const modal = document.getElementById('coverPickerModal')
            if (modal) modal.style.display = 'flex'
        }

        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('coverPickerModal')
            if (modal) modal.addEventListener('click', e => { if (e.target === modal) modal.style.display = 'none' })
        })
    </script>

    <!-- Modal sélection fond de profil -->
    <% if (isOwnProfile) { %>
    <div id="coverPickerModal">
        <div class="cover-picker-sheet">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                <div>
                    <h3><i class="fa-solid fa-image" style="color:var(--primary);margin-right:6px;"></i>Choisir un fond</h3>
                    <p>Clique sur une photo pour l'appliquer immédiatement</p>
                </div>
                <button onclick="document.getElementById('coverPickerModal').style.display='none'" style="background:var(--bg-secondary);border:none;border-radius:50%;width:32px;height:32px;cursor:pointer;font-size:16px;color:var(--text-secondary);display:flex;align-items:center;justify-content:center;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    </div>
    <% } %>
</body>
</html>
