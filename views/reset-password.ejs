<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-lock brand-icon"></i>
                <h2>Nouveau mot de passe</h2>
                <p>Entrez le code reçu par email et choisissez un nouveau mot de passe sécurisé.</p>
                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-envelope"></i>
                        <span>Email : <strong><%= email %></strong></span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-clock"></i>
                        <span>Code valable 15 minutes</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-check-circle"></i>
                        <span>Choisissez un mot de passe sécurisé</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Réinitialisation</h2>
                <p class="auth-subtitle">Code envoyé à <strong><%= email %></strong></p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success[0] %></span>
                    </div>
                <% } %>

                <form action="/reset-password" method="POST">
                    <div class="form-group">
                        <label>Code de réinitialisation</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-hashtag"></i>
                            <input type="text" name="code" placeholder="6 chiffres" maxlength="6" inputmode="numeric" pattern="[0-9]{6}" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Nouveau mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="motDePasse" placeholder="Minimum 6 caractères" minlength="6" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="confirmMotDePasse" placeholder="Confirmez votre mot de passe" minlength="6" required>
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-check"></i>
                        Réinitialiser
                    </button>
                </form>

                <div class="auth-footer">
                    <a href="/login">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
