<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
    <style>
        #stories-container {
            display: flex;
            gap: 14px;
            padding: 8px 0 16px;
            overflow-x: auto;
            scrollbar-width: none;
            margin-bottom: 8px;
        }
        #stories-container::-webkit-scrollbar { display: none; }
        .story-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            cursor: pointer;
        }
        .story-ring {
            width: 62px;
            height: 62px;
            border-radius: 50%;
            padding: 2.5px;
            background: linear-gradient(45deg, #f59e0b, #ef4444, #7c3aed, #4f46e5);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-ring.seen { background: #d1d5db; }
        .story-ring-inner {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2.5px solid #fff;
            overflow: hidden;
        }
        .story-ring-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .story-add-btn {
            width: 62px;
            height: 62px;
            border-radius: 50%;
            background: var(--primary-light);
            border: 2px dashed var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 22px;
            color: var(--primary);
        }
        .story-add-btn:hover { background: var(--primary); color: #fff; }
        .story-label {
            font-size: 11px;
            color: var(--text-secondary);
            text-align: center;
            max-width: 62px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .story-viewer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 99999;
            flex-direction: column;
        }
        .story-viewer-overlay.active { display: flex; }
        .story-progress-bar {
            display: flex;
            gap: 4px;
            padding: 12px;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10;
        }
        .story-progress-segment {
            flex: 1;
            height: 3px;
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
            overflow: hidden;
        }
        .story-progress-fill {
            height: 100%;
            background: #fff;
            border-radius: 3px;
            width: 0%;
        }
        .story-viewer-header {
            position: absolute;
            top: 28px;
            left: 0;
            right: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 16px;
            z-index: 10;
        }
        .story-viewer-header img {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.6);
            object-fit: cover;
        }
        .story-viewer-author { color: #fff; font-weight: 700; font-size: 14px; }
        .story-viewer-time { color: rgba(255,255,255,0.7); font-size: 12px; }
        .story-viewer-close {
            color: #fff;
            font-size: 24px;
            cursor: pointer;
            margin-left: auto;
            background: none;
            border: none;
        }
        .story-viewer-media {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .story-viewer-media img,
        .story-viewer-media video { width: 100%; height: 100%; object-fit: contain; }
        .story-viewer-text-overlay {
            position: absolute;
            bottom: 80px;
            left: 0;
            right: 0;
            text-align: center;
            padding: 0 24px;
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            text-shadow: 0 2px 8px rgba(0,0,0,0.7);
        }
        .story-viewer-nav-prev {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 100px;
            width: 40%;
            cursor: pointer;
            z-index: 5;
        }
        .story-viewer-nav-next {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 100px;
            width: 60%;
            cursor: pointer;
            z-index: 5;
        }
        .story-viewer-footer {
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
            z-index: 10;
        }
        .story-emoji-reactions { display: flex; gap: 6px; }
        .story-emoji-btn {
            background: rgba(255,255,255,0.15);
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-views-count {
            color: rgba(255,255,255,0.8);
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .story-creator-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            z-index: 99999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .story-creator-overlay.active { display: flex; }
        .story-creator-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 24px;
            width: 100%;
            max-width: 420px;
        }
        .story-creator-preview {
            width: 100%;
            height: 220px;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 16px;
            background: var(--background);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            cursor: pointer;
        }
        .story-creator-preview img,
        .story-creator-preview video { width: 100%; height: 100%; object-fit: cover; }
        .story-color-picker { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
        .story-color-swatch {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid transparent;
            transition: transform 0.15s;
        }
        .story-color-swatch.selected,
        .story-color-swatch:hover { border-color: var(--text-primary); transform: scale(1.1); }

        .share-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 500;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .share-modal-overlay.active { display: flex; }
        .share-modal-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 24px;
            width: 100%;
            max-width: 480px;
            box-shadow: var(--shadow-lg);
        }

        @media (max-width: 480px) {
            .story-ring { width: 54px; height: 54px; }
            .story-add-btn { width: 54px; height: 54px; font-size: 18px; }
            .story-label { font-size: 10px; max-width: 54px; }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'feed' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'feed' }) %>

        <main class="feed">

            <div class="page-header">
                <div>
                    <h1>Fil d'actualité</h1>
                    <div class="subtitle">Découvre les dernières publications de tes amis</div>
                </div>
            </div>

            <!-- ===== STORIES ===== -->
            <div id="stories-container">
                <div class="story-item" id="addStoryStatic">
                    <div class="story-add-btn" onclick="openStoryCreator()">
                        <i class="fa-solid fa-plus"></i>
                    </div>
                    <div class="story-label">Ta story</div>
                </div>
            </div>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- Formulaire de publication -->
            <div class="card post-form">
                <form action="/post" method="POST" enctype="multipart/form-data">
                    <div class="post-form-top">
                        <img src="<%= user.photoProfil %>" class="post-form-avatar" alt="">
                        <textarea name="contenu" placeholder="Quoi de neuf, <%= user.nom.split(' ')[0] %> ?" required></textarea>
                    </div>
                    <div id="imagePreview" style="margin:0 0 10px 56px;"></div>
                    <div class="post-form-footer">
                        <div class="post-form-tools">
                            <label for="imageInput" title="Ajouter une image">
                                <i class="fa-solid fa-image"></i>
                            </label>
                            <input type="file" id="imageInput" name="image" accept="image/*" style="display:none">
                        </div>
                        <button type="submit" class="btn">
                            <i class="fa-solid fa-paper-plane"></i> Publier
                        </button>
                    </div>
                </form>
            </div>

            <!-- Liste des posts -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                    <p>Commence par publier ou ajoute des amis !</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post" data-id="<%= post._id %>">
                    <div class="post-header">
                        <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <% if (post.isShared && post.sharedFrom) { %>
                        <% if (post.shareMessage) { %>
                            <div class="share-message" style="font-size:14.5px; line-height:1.6; color:var(--text-primary); margin-bottom:10px; white-space:pre-wrap;"><%= post.shareMessage %></div>
                        <% } %>
                        <div style="border:1.5px solid var(--border); border-radius:var(--radius-sm); padding:14px; margin-bottom:12px; background:var(--background);">
                            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                                <img src="<%= post.sharedFrom.auteur.photoProfil %>" style="width:28px; height:28px; border-radius:50%; object-fit:cover; border:1px solid var(--border);" alt="">
                                <div>
                                    <div style="font-weight:700; font-size:13px; color:var(--text-primary);">
                                        <%= post.sharedFrom.auteur.nom %>
                                        <%- include('partials/badges', { badges: post.sharedFrom.auteur.badges || [] }) %>
                                    </div>
                                    <div style="font-size:11px; color:var(--text-muted);">
                                        <%= new Date(post.sharedFrom.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                    </div>
                                </div>
                            </div>
                            <div style="font-size:13.5px; color:var(--text-secondary); line-height:1.5; white-space:pre-wrap;"><%= post.sharedFrom.contenu %></div>
                            <% if (post.sharedFrom.image) { %>
                                <img src="<%= post.sharedFrom.image %>" style="width:100%; border-radius:6px; margin-top:8px; max-height:200px; object-fit:cover;" alt="">
                            <% } %>
                        </div>
                    <% } else { %>
                        <% if (post.contenu) { %>
                            <div class="post-content"><%= post.contenu %></div>
                        <% } %>
                        <% if (post.image) { %>
                            <img src="<%= post.image %>" class="post-image" alt="">
                        <% } %>
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <button onclick="openShareModal('<%= post._id %>')">
                            <i class="fa-solid fa-share-nodes"></i>
                            <span class="shares-count"><%= post.sharesCount || 0 %></span> Partager
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges || [] }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">À PROPOS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.6;">
                Bienvenue sur <strong>SocialApp</strong> <i class="fa-solid fa-rocket"></i><br>
                Partage, connecte et discute avec tes amis !
            </p>
        </aside>
    </div>

    <!-- ===== MODAL PARTAGE ===== -->
    <div class="share-modal-overlay" id="share-modal-overlay">
        <div class="share-modal-card">
            <div style="font-size:16px; font-weight:700; color:var(--text-primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                <i class="fa-solid fa-share-nodes" style="color:var(--primary);"></i>
                Partager la publication
            </div>
            <div class="form-group" style="margin-bottom:14px;">
                <div class="input-wrapper">
                    <i class="fa-solid fa-pen"></i>
                    <input type="text" id="share-message-input" placeholder="Ajoute un message (optionnel)" maxlength="300">
                </div>
            </div>
            <div style="display:flex; gap:10px;">
                <button onclick="closeShareModal()" class="btn btn-secondary">Annuler</button>
                <button onclick="submitShare()" class="btn" id="share-submit-btn">
                    <i class="fa-solid fa-share-nodes"></i> Partager
                </button>
            </div>
        </div>
    </div>

    <!-- ===== OVERLAY STORIES ===== -->
    <div class="story-viewer-overlay" id="story-viewer-overlay">
        <div class="story-progress-bar" id="story-progress-container"></div>
        <div class="story-viewer-header">
            <img src="" alt="" id="story-author-avatar">
            <div>
                <div class="story-viewer-author" id="story-author-name"></div>
                <div class="story-viewer-time" id="story-time"></div>
            </div>
            <button class="story-viewer-close" id="story-viewer-close"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="story-viewer-media" id="story-media-container"></div>
        <div class="story-viewer-text-overlay" id="story-text-overlay"></div>
        <div class="story-viewer-nav-prev" onclick="goToPrevStory()"></div>
        <div class="story-viewer-nav-next" onclick="goToNextStory()"></div>
        <div class="story-viewer-footer">
            <div class="story-views-count" id="storyViewsCount" style="cursor:pointer; color:rgba(255,255,255,0.8); font-size:12px; display:flex; align-items:center; gap:4px;">
                <i class="fa-regular fa-eye"></i>
                <span id="story-views-count">0</span>
            </div>
            <div class="story-emoji-reactions">
                <button class="story-emoji-btn" onclick="reactToStory('❤️')">❤️</button>
                <button class="story-emoji-btn" onclick="reactToStory('😂')">😂</button>
                <button class="story-emoji-btn" onclick="reactToStory('😮')">😮</button>
                <button class="story-emoji-btn" onclick="reactToStory('🔥')">🔥</button>
                <button class="story-emoji-btn" onclick="reactToStory('👏')">👏</button>
            </div>
        </div>
    </div>

    <!-- ===== CREATEUR DE STORY ===== -->
    <div class="story-creator-overlay" id="story-creator-overlay">
        <div class="story-creator-card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                <h3 style="font-size:16px; font-weight:700; color:var(--text-primary);">
                    <i class="fa-solid fa-circle-plus" style="color:var(--primary);"></i> Créer une story
                </h3>
                <button onclick="closeStoryCreator()" style="background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:18px;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="story-creator-preview" id="story-preview-area" style="background:#4f46e5;" onclick="document.getElementById('story-file-input').click()">
                <div style="text-align:center; color:rgba(255,255,255,0.7);">
                    <i class="fa-solid fa-image" style="font-size:32px; margin-bottom:8px; display:block;"></i>
                    <div style="font-size:13px;">Clique pour ajouter une photo ou vidéo</div>
                </div>
            </div>
            <input type="file" id="story-file-input" accept="image/*,video/*" style="display:none" onchange="handleStoryFileSelect(event)">
            <div style="font-size:12px; font-weight:600; color:var(--text-secondary); margin-bottom:6px; margin-top:4px;">Couleur de fond</div>
            <div class="story-color-picker" id="story-color-picker"></div>
            <div class="form-group" style="margin-bottom:14px;">
                <div class="input-wrapper">
                    <i class="fa-solid fa-pen"></i>
                    <input type="text" id="story-text-input" placeholder="Ajouter un texte (optionnel)" maxlength="200">
                </div>
            </div>
            <div style="display:flex; gap:10px;">
                <button onclick="closeStoryCreator()" class="btn btn-secondary">Annuler</button>
                <button onclick="publishStory()" class="btn" id="story-publish-btn">
                    <i class="fa-solid fa-paper-plane"></i> Publier
                </button>
            </div>
        </div>
    </div>

    <script src="/js/feed.js"></script>
    <script>
        const currentUserId = "<%= currentUserId %>"

        // Les fonctions toggleComments et preview image restent ici
        function toggleComments(postId) {
            const el = document.getElementById("comments-" + postId)
            el.style.display = el.style.display === "none" ? "block" : "none"
        }

        document.getElementById("imageInput").addEventListener("change", function(e) {
            const preview = document.getElementById("imagePreview")
            preview.innerHTML = ""
            const file = e.target.files[0]
            if (file) {
                const img = document.createElement("img")
                img.src = URL.createObjectURL(file)
                img.style.cssText = "max-width:100%;border-radius:10px;max-height:300px;"
                preview.appendChild(img)
            }
        })
    </script>
</body>
</html>
