<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>

    <!-- ===== CSS DES STORIES ===== -->
    <style>
        .stories-bar {
            display: flex;
            gap: 14px;
            padding: 12px 0 16px;
            overflow-x: auto;
            scrollbar-width: none;
            border-bottom: 1px solid #e5e7eb;
            margin-bottom: 16px;
        }
        .stories-bar::-webkit-scrollbar { display: none; }

        .story-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            cursor: pointer;
        }
        .story-avatar {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            padding: 2px;
            background: linear-gradient(135deg, #f09433, #bc1888);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-avatar.seen {
            background: #d1d5db;
        }
        .story-avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2px solid #fff;
            object-fit: cover;
        }
        .story-name {
            font-size: 11px;
            color: #6b7280;
            max-width: 68px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            text-align: center;
        }
        .story-add-btn {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: #4f46e5;
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 26px;
            border: 2px solid #fff;
            box-shadow: 0 0 0 2px #4f46e5;
            flex-shrink: 0;
        }
        .story-add-btn span {
            font-size: 10px;
            font-weight: 600;
            margin-top: 2px;
        }
        .story-add-btn:hover {
            background: #4338ca;
            transform: scale(1.04);
        }

        .story-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 9999;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .story-overlay.active {
            display: flex;
            opacity: 1;
        }
        .story-progress {
            position: fixed;
            top: 12px;
            left: 16px;
            right: 16px;
            display: flex;
            gap: 4px;
            z-index: 10001;
            padding: 0 4px;
        }
        .story-progress-bar {
            flex: 1;
            height: 3px;
            background: rgba(255,255,255,0.3);
            border-radius: 4px;
            overflow: hidden;
        }
        .story-progress-bar .fill {
            height: 100%;
            width: 0%;
            background: #fff;
            border-radius: 4px;
            animation: progressAnim 5s linear forwards;
        }
        @keyframes progressAnim {
            0% { width: 0%; }
            100% { width: 100%; }
        }
        .story-media {
            width: 100%;
            max-width: 420px;
            max-height: 90vh;
            object-fit: contain;
            border-radius: 12px;
            cursor: pointer;
            user-select: none;
        }
        .story-author-info {
            position: fixed;
            top: 32px;
            left: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 10000;
            color: #fff;
            pointer-events: none;
        }
        .story-author-info img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid #fff;
            object-fit: cover;
        }
        .story-author-info span {
            font-weight: 600;
            font-size: 15px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.6);
        }
        .story-close {
            position: fixed;
            top: 28px;
            right: 20px;
            color: #fff;
            font-size: 28px;
            cursor: pointer;
            z-index: 10001;
            text-shadow: 0 2px 12px rgba(0,0,0,0.7);
            transition: 0.2s;
            pointer-events: auto;
        }
        .story-close:hover {
            transform: scale(1.1);
        }
        .story-views {
            position: fixed;
            bottom: 60px;
            left: 0;
            right: 0;
            text-align: center;
            color: rgba(255,255,255,0.7);
            font-size: 13px;
            font-weight: 400;
            z-index: 10000;
            pointer-events: none;
            text-shadow: 0 2px 8px rgba(0,0,0,0.5);
        }
        .story-views i {
            margin-right: 6px;
        }

        @media (max-width: 480px) {
            .story-avatar { width: 56px; height: 56px; }
            .story-add-btn { width: 56px; height: 56px; font-size: 22px; }
            .story-name { font-size: 10px; max-width: 56px; }
        }
    </style>

</head>
<body>
    <%- include('partials/navbar', { currentPage: 'feed' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'feed' }) %>

        <main class="feed">

            <div class="page-header">
                <div>
                    <h1>Fil d'actualité</h1>
                    <div class="subtitle">Découvre les dernières publications de tes amis</div>
                </div>
            </div>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- ===== STORIES BAR ===== -->
            <div class="stories-bar" id="storiesBar">
                <div class="story-add-btn" id="addStoryBtn">
                    <i class="fa-solid fa-plus"></i>
                    <span>Ajouter</span>
                </div>
                <input type="file" id="storyInput" accept="image/*" style="display:none">
            </div>

            <!-- ===== STORIES OVERLAY ===== -->
            <div class="story-overlay" id="storyOverlay">
                <div class="story-progress" id="storyProgress"></div>
                <div class="story-close" id="storyClose"><i class="fa-solid fa-xmark"></i></div>
                <div class="story-author-info">
                    <img id="storyAuthorAvatar" src="" alt="">
                    <span id="storyAuthorName"></span>
                </div>
                <img class="story-media" id="storyMedia" src="" alt="">
                <div class="story-views">
                    <i class="fa-regular fa-eye"></i> <span id="storyViewCount">0</span> vues
                </div>
            </div>

            <!-- Formulaire de publication -->
            <div class="card post-form">
                <form action="/post" method="POST" enctype="multipart/form-data">
                    <div class="post-form-top">
                        <img src="<%= user.photoProfil %>" class="post-form-avatar" alt="">
                        <textarea name="contenu" placeholder="Quoi de neuf, <%= user.nom.split(' ')[0] %> ?" required></textarea>
                    </div>
                    <div id="imagePreview" style="margin:0 0 10px 56px;"></div>
                    <div class="post-form-footer">
                        <div class="post-form-tools">
                            <label for="imageInput" title="Ajouter une image">
                                <i class="fa-solid fa-image"></i>
                            </label>
                            <input type="file" id="imageInput" name="image" accept="image/*" style="display:none">
                        </div>
                        <button type="submit" class="btn">
                            <i class="fa-solid fa-paper-plane"></i> Publier
                        </button>
                    </div>
                </form>
            </div>

            <!-- Liste des posts -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                    <p>Commence par publier ou ajoute des amis !</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post" data-id="<%= post._id %>">
                    <div class="post-header">
                        <!-- ===== AVATAR DU POST AVEC EFFET (si présent) ===== -->
                        <div class="<%= post.auteur.profileEffect ? 'effect-' + post.auteur.profileEffect : '' %>" style="display:inline-block; position:relative;">
                            <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        </div>
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <!-- Message de partage -->
                    <% if (post.isShared && post.shareMessage) { %>
                        <div class="share-message"><%= post.shareMessage %></div>
                    <% } %>

                    <!-- Post original partagé -->
                    <% if (post.isShared && post.sharedFrom) { %>
                        <div class="shared-post-preview">
                            <div class="shared-post-header">
                                <img src="<%= post.sharedFrom.auteur.photoProfil %>" alt="">
                                <div>
                                    <div class="shared-post-author">
                                        <%= post.sharedFrom.auteur.nom %>
                                        <%- include('partials/badges', { badges: post.sharedFrom.auteur.badges || [] }) %>
                                    </div>
                                    <div class="shared-post-date">
                                        <%= new Date(post.sharedFrom.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                    </div>
                                </div>
                            </div>
                            <div class="shared-post-content"><%= post.sharedFrom.contenu %></div>
                            <% if (post.sharedFrom.image) { %>
                                <img src="<%= post.sharedFrom.image %>" class="shared-post-image" alt="">
                            <% } %>
                        </div>
                    <% } else { %>
                        <!-- Post normal -->
                        <% if (post.contenu) { %>
                            <div class="post-content"><%= post.contenu %></div>
                        <% } %>
                        <% if (post.image) { %>
                            <img src="<%= post.image %>" class="post-image" alt="">
                        <% } %>
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <button onclick="openShareModal('<%= post._id %>')">
                            <i class="fa-solid fa-share-nodes"></i>
                            <span class="share-count" data-id="<%= post._id %>">
                                <span class="shares-count"><%= post.sharesCount || 0 %></span>
                            </span> Partager
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges || [] }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">À PROPOS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.6;">
                Bienvenue sur <strong>SocialApp</strong><br>
                Partage, connecte et discute avec tes amis !
            </p>
        </aside>
    </div>

    <!-- ========== MODAL DE PARTAGE ========== -->
    <div class="share-modal-overlay" id="share-modal-overlay">
        <div class="share-modal-card">
            <div class="share-modal-title">
                <i class="fa-solid fa-share-nodes" style="color:var(--primary);"></i>
                Partager la publication
            </div>

            <div class="form-group" style="margin-bottom:14px;">
                <div class="input-wrapper">
                    <i class="fa-solid fa-pen"></i>
                    <input type="text" id="share-message-input"
                           placeholder="Ajoute un message (optionnel)" maxlength="300">
                </div>
            </div>

            <div style="display:flex; gap:10px;">
                <button onclick="closeShareModal()" class="btn btn-secondary">
                    Annuler
                </button>
                <button onclick="submitShare()" class="btn" id="share-submit-btn">
                    <i class="fa-solid fa-share-nodes"></i> Partager
                </button>
            </div>
        </div>
    </div>

    <script src="/js/feed.js"></script>
    <script>
        // ============================================================
        // STORIES — TOUT EN UN (intégré)
        // ============================================================
        let currentStoryIndex = 0;
        let storiesList = [];
        let storyTimer = null;

        const currentUserId = "<%= currentUserId %>";

        async function loadStories() {
            try {
                const res = await fetch('/api/stories');
                const data = await res.json();
                storiesList = data.stories || [];
                renderStoriesBar();
            } catch (e) {
                console.error('Erreur chargement stories:', e);
            }
        }

        function renderStoriesBar() {
            const bar = document.getElementById('storiesBar');
            if (!bar) return;

            // Garder le bouton "Ajouter"
            const addBtn = document.getElementById('addStoryBtn');
            bar.innerHTML = '';
            bar.appendChild(addBtn);
            bar.appendChild(document.getElementById('storyInput'));

            if (storiesList.length === 0) return;

            storiesList.forEach((story, index) => {
                const isSeen = story.vues && story.vues.includes(currentUserId);
                const item = document.createElement('div');
                item.className = 'story-item';
                item.innerHTML = `
                    <div class="story-avatar ${isSeen ? 'seen' : ''}">
                        <img src="${story.auteur.photoProfil}" alt="">
                    </div>
                    <div class="story-name">${story.auteur.nom}</div>
                `;
                item.addEventListener('click', () => openStory(index));
                bar.appendChild(item);
            });
        }

        function openStory(index) {
            currentStoryIndex = index;
            const story = storiesList[index];
            if (!story) return;

            const overlay = document.getElementById('storyOverlay');
            const media = document.getElementById('storyMedia');
            const authorName = document.getElementById('storyAuthorName');
            const authorAvatar = document.getElementById('storyAuthorAvatar');
            const viewCount = document.getElementById('storyViewCount');
            const progressContainer = document.getElementById('storyProgress');

            media.src = story.media;
            media.alt = `Story de ${story.auteur.nom}`;
            authorName.textContent = story.auteur.nom;
            authorAvatar.src = story.auteur.photoProfil;
            viewCount.textContent = story.vues ? story.vues.length : 0;

            progressContainer.innerHTML = `
                <div class="story-progress-bar active">
                    <div class="fill" style="animation-duration: 5s;"></div>
                </div>
            `;

            overlay.classList.add('active');

            fetch(`/api/stories/${story._id}/view`, { method: 'POST' });

            clearTimeout(storyTimer);
            storyTimer = setTimeout(() => {
                nextStory();
            }, 5000);
        }

        function nextStory() {
            const next = currentStoryIndex + 1;
            if (next < storiesList.length) {
                openStory(next);
            } else {
                closeStory();
            }
        }

        function closeStory() {
            clearTimeout(storyTimer);
            document.getElementById('storyOverlay').classList.remove('active');
        }

        // Initialisation des stories
        document.addEventListener('DOMContentLoaded', function() {
            loadStories();

            document.getElementById('addStoryBtn').addEventListener('click', function() {
                document.getElementById('storyInput').click();
            });

            document.getElementById('storyInput').addEventListener('change', async function(e) {
                const file = e.target.files[0];
                if (!file) return;
                const formData = new FormData();
                formData.append('media', file);
                try {
                    const res = await fetch('/api/stories/upload', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.success) {
                        loadStories();
                    } else {
                        alert('Erreur : ' + data.error);
                    }
                } catch (err) {
                    alert('Erreur réseau');
                }
                this.value = '';
            });

            document.getElementById('storyClose').addEventListener('click', closeStory);
            document.getElementById('storyOverlay').addEventListener('click', function(e) {
                if (e.target === this) closeStory();
            });
        });

        // ============================================================
        // FONCTIONS EXISTANTES
        // ============================================================
        function toggleComments(postId) {
            const el = document.getElementById('comments-' + postId);
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
        }

        document.getElementById('imageInput').addEventListener('change', function(e) {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            const file = e.target.files[0];
            if (file) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.style.maxWidth = '100%';
                img.style.borderRadius = '10px';
                img.style.maxHeight = '300px';
                preview.appendChild(img);
            }
        });

        // ============================================================
        // MODAL DE PARTAGE
        // ============================================================
        let sharePostId = null;

        function openShareModal(postId) {
            sharePostId = postId;
            document.getElementById('share-modal-overlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeShareModal() {
            document.getElementById('share-modal-overlay').classList.remove('active');
            document.body.style.overflow = '';
            document.getElementById('share-message-input').value = '';
        }

        async function submitShare() {
            const message = document.getElementById('share-message-input').value.trim();
            const btn = document.getElementById('share-submit-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Partager...';

            try {
                const res = await fetch('/post/share', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ postId: sharePostId, message })
                });
                const data = await res.json();
                if (data.success) {
                    alert('✅ Publication partagée !');
                    location.reload();
                } else {
                    alert('❌ ' + data.error);
                }
            } catch (e) {
                alert('Erreur réseau');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-share-nodes"></i> Partager';
                closeShareModal();
            }
        }

        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('share-modal-overlay')) {
                closeShareModal();
            }
        });
    </script>
</body>
</html>
