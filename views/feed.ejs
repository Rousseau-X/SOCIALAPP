<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
    
    <!-- ===== CSS DES STORIES (uniquement pour cette page) ===== -->
    <style>
        #stories-container {
            display: flex;
            gap: 14px;
            padding: 8px 0 16px;
            overflow-x: auto;
            scrollbar-width: none;
            margin-bottom: 8px;
        }
        #stories-container::-webkit-scrollbar { display: none; }
        
        .story-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            cursor: pointer;
        }
        .story-ring {
            width: 62px;
            height: 62px;
            border-radius: 50%;
            padding: 2.5px;
            background: linear-gradient(45deg, #f59e0b, #ef4444, #7c3aed, #4f46e5);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-ring.seen { background: #d1d5db; }
        .story-ring-inner {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2.5px solid #fff;
            overflow: hidden;
        }
        .story-ring-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .story-add-btn {
            width: 62px;
            height: 62px;
            border-radius: 50%;
            background: var(--primary-light);
            border: 2px dashed var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 22px;
            color: var(--primary);
        }
        .story-add-btn:hover {
            background: var(--primary);
            color: #fff;
        }
        .story-label {
            font-size: 11px;
            color: var(--text-secondary);
            text-align: center;
            max-width: 62px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Overlay stories */
        .story-viewer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 99999;
            flex-direction: column;
        }
        .story-viewer-overlay.active { display: flex; }
        .story-progress-bar {
            display: flex;
            gap: 4px;
            padding: 12px;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10;
        }
        .story-progress-segment {
            flex: 1;
            height: 3px;
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
            overflow: hidden;
        }
        .story-progress-fill {
            height: 100%;
            background: #fff;
            border-radius: 3px;
            width: 0%;
        }
        .story-viewer-header {
            position: absolute;
            top: 28px;
            left: 0;
            right: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 16px;
            z-index: 10;
        }
        .story-viewer-header img {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.6);
            object-fit: cover;
        }
        .story-viewer-author {
            color: #fff;
            font-weight: 700;
            font-size: 14px;
        }
        .story-viewer-time {
            color: rgba(255,255,255,0.7);
            font-size: 12px;
        }
        .story-viewer-close {
            color: #fff;
            font-size: 24px;
            cursor: pointer;
            margin-left: auto;
            background: none;
            border: none;
        }
        .story-viewer-media {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .story-viewer-media img,
        .story-viewer-media video {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .story-viewer-text-overlay {
            position: absolute;
            bottom: 80px;
            left: 0;
            right: 0;
            text-align: center;
            padding: 0 24px;
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            text-shadow: 0 2px 8px rgba(0,0,0,0.7);
        }
        .story-viewer-nav-prev {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 100px;
            width: 40%;
            cursor: pointer;
            z-index: 5;
        }
        .story-viewer-nav-next {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 100px;
            width: 60%;
            cursor: pointer;
            z-index: 5;
        }
        .story-viewer-footer {
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
            z-index: 10;
        }
        .story-emoji-reactions {
            display: flex;
            gap: 6px;
        }
        .story-emoji-btn {
            background: rgba(255,255,255,0.15);
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-views-count {
            color: rgba(255,255,255,0.8);
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .story-creator-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            z-index: 99999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .story-creator-overlay.active { display: flex; }
        .story-creator-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 24px;
            width: 100%;
            max-width: 420px;
        }
        .story-creator-preview {
            width: 100%;
            height: 220px;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 16px;
            background: var(--background);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .story-creator-preview img,
        .story-creator-preview video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .story-color-picker {
            display: flex;
            gap: 8px;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }
        .story-color-swatch {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid transparent;
        }
        .story-color-swatch.selected,
        .story-color-swatch:hover {
            border-color: var(--text-primary);
            transform: scale(1.1);
        }
        @media (max-width: 480px) {
            .story-ring { width: 54px; height: 54px; }
            .story-add-btn { width: 54px; height: 54px; font-size: 18px; }
            .story-label { font-size: 10px; max-width: 54px; }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'feed' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'feed' }) %>

        <main class="feed">

            <div class="page-header">
                <div>
                    <h1>Fil d'actualité</h1>
                    <div class="subtitle">Découvre les dernières publications de tes amis</div>
                </div>
            </div>

            <!-- ===== STORIES ===== -->
            <div id="stories-container"></div>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- Formulaire de publication -->
            <div class="card post-form">
                <form action="/post" method="POST" enctype="multipart/form-data">
                    <div class="post-form-top">
                        <img src="<%= user.photoProfil %>" class="post-form-avatar" alt="">
                        <textarea name="contenu" placeholder="Quoi de neuf, <%= user.nom.split(' ')[0] %> ?" required></textarea>
                    </div>
                    <div id="imagePreview" style="margin:0 0 10px 56px;"></div>
                    <div class="post-form-footer">
                        <div class="post-form-tools">
                            <label for="imageInput" title="Ajouter une image">
                                <i class="fa-solid fa-image"></i>
                            </label>
                            <input type="file" id="imageInput" name="image" accept="image/*" style="display:none">
                        </div>
                        <button type="submit" class="btn">
                            <i class="fa-solid fa-paper-plane"></i> Publier
                        </button>
                    </div>
                </form>
            </div>

            <!-- Liste des posts -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                    <p>Commence par publier ou ajoute des amis !</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post">
                    <div class="post-header">
                        <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <div class="post-content"><%= post.contenu %></div>

                    <% if (post.image) { %>
                        <img src="<%= post.image %>" class="post-image" alt="">
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">À PROPOS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.6;">
                Bienvenue sur <strong>SocialApp</strong> <i class="fa-solid fa-rocket"></i><br>
                Partage, connecte et discute avec tes amis !
            </p>
        </aside>
    </div>

    <script src="/js/feed.js"></script>
    <script>
        // ============================================================
        // STORIES — TOUT EN UN
        // ============================================================
        let currentStoryGroups = []
        let currentGroupIndex = 0
        let currentStoryIndex = 0
        let storyTimer = null
        const STORY_DURATION = 5000

        const currentUserId = "<%= currentUserId %>";

        async function loadStories() {
            try {
                const res = await fetch("/stories")
                const data = await res.json()
                if (!data.success) return
                currentStoryGroups = data.groups || []
                renderStories()
            } catch (e) {
                console.error("Erreur loadStories:", e)
            }
        }

        function renderStories() {
            const container = document.getElementById("stories-container")
            if (!container) return
            container.innerHTML = ""

            // Bouton Ajouter
            const addItem = document.createElement("div")
            addItem.className = "story-item"
            addItem.innerHTML = `
                <div class="story-add-btn" onclick="openStoryCreator()">
                    <i class="fa-solid fa-plus"></i>
                </div>
                <div class="story-label">Ta story</div>
            `
            container.appendChild(addItem)

            currentStoryGroups.forEach((group, idx) => {
                const item = document.createElement("div")
                item.className = "story-item"
                const allSeen = !group.hasUnseen
                item.innerHTML = `
                    <div class="story-ring ${allSeen ? 'seen' : ''}">
                        <div class="story-ring-inner">
                            <img src="${group.user.photoProfil}" alt="">
                        </div>
                    </div>
                    <div class="story-label">${group.user.nom.split(" ")[0]}</div>
                `
                item.onclick = () => openStoryViewer(idx)
                container.appendChild(item)
            })
        }

        function openStoryViewer(groupIndex, storyIndex = 0) {
            currentGroupIndex = groupIndex
            currentStoryIndex = storyIndex
            const overlay = document.getElementById("story-viewer-overlay")
            if (!overlay) return
            overlay.classList.add("active")
            showStory()
            document.body.style.overflow = "hidden"
        }

        function closeStoryViewer() {
            const overlay = document.getElementById("story-viewer-overlay")
            if (!overlay) return
            overlay.classList.remove("active")
            stopStoryTimer()
            document.body.style.overflow = ""
        }

        function showStory() {
            stopStoryTimer()
            const group = currentStoryGroups[currentGroupIndex]
            if (!group) { closeStoryViewer(); return }
            const story = group.stories[currentStoryIndex]
            if (!story) { closeStoryViewer(); return }

            fetch(`/stories/${story._id}/view`, { method: "POST" })

            // Progress bars
            const progressContainer = document.getElementById("story-progress-container")
            if (progressContainer) {
                progressContainer.innerHTML = ""
                group.stories.forEach((_, i) => {
                    const seg = document.createElement("div")
                    seg.className = "story-progress-segment"
                    const fill = document.createElement("div")
                    fill.className = "story-progress-fill"
                    if (i < currentStoryIndex) fill.style.width = "100%"
                    seg.appendChild(fill)
                    progressContainer.appendChild(seg)
                })
            }

            // Header
            document.getElementById("story-author-avatar").src = group.user.photoProfil
            document.getElementById("story-author-name").textContent = group.user.nom
            document.getElementById("story-time").textContent = "à l'instant"

            // Media
            const mediaContainer = document.getElementById("story-media-container")
            if (story.couleurFond) {
                mediaContainer.style.background = story.couleurFond
                mediaContainer.innerHTML = ""
            } else if (story.mediaType === "video") {
                mediaContainer.style.background = "#000"
                mediaContainer.innerHTML = `<video src="${story.media}" autoplay muted playsinline style="width:100%;height:100%;object-fit:contain;"></video>`
            } else {
                mediaContainer.style.background = "#000"
                mediaContainer.innerHTML = `<img src="${story.media}" style="width:100%;height:100%;object-fit:contain;" alt="">`
            }

            // Texte
            const textEl = document.getElementById("story-text-overlay")
            textEl.textContent = story.texte || ""
            textEl.style.display = story.texte ? "block" : "none"

            // Vues
            document.getElementById("story-views-count").textContent = story.vues?.length || 0

            // Démarrer le timer
            startStoryTimer()
        }

        function startStoryTimer() {
            const fills = document.querySelectorAll(".story-progress-fill")
            if (fills.length === 0 || currentStoryIndex >= fills.length) return
            const fill = fills[currentStoryIndex]
            fill.style.transition = `width ${STORY_DURATION}ms linear`
            fill.style.width = "100%"

            storyTimer = setTimeout(() => {
                goToNextStory()
            }, STORY_DURATION)
        }

        function stopStoryTimer() {
            if (storyTimer) {
                clearTimeout(storyTimer)
                storyTimer = null
            }
        }

        function goToNextStory() {
            const group = currentStoryGroups[currentGroupIndex]
            if (!group) { closeStoryViewer(); return }
            if (currentStoryIndex < group.stories.length - 1) {
                currentStoryIndex++
                showStory()
            } else if (currentGroupIndex < currentStoryGroups.length - 1) {
                currentGroupIndex++
                currentStoryIndex = 0
                showStory()
            } else {
                closeStoryViewer()
            }
        }

        function goToPrevStory() {
            if (currentStoryIndex > 0) {
                currentStoryIndex--
                showStory()
            } else if (currentGroupIndex > 0) {
                currentGroupIndex--
                const prevGroup = currentStoryGroups[currentGroupIndex]
                currentStoryIndex = prevGroup.stories.length - 1
                showStory()
            }
        }

        function openStoryCreator() {
            document.getElementById("story-creator-overlay").classList.add("active")
            document.body.style.overflow = "hidden"
            renderColorPicker()
        }

        function closeStoryCreator() {
            document.getElementById("story-creator-overlay").classList.remove("active")
            document.body.style.overflow = ""
            document.getElementById("story-file-input").value = ""
            document.getElementById("story-text-input").value = ""
            selectedFile = null
            document.getElementById("story-preview-area").style.background = selectedColor || "#4f46e5"
            document.getElementById("story-preview-area").innerHTML = `
                <div style="text-align:center; color:rgba(255,255,255,0.7);">
                    <i class="fa-solid fa-image" style="font-size:32px; margin-bottom:8px; display:block;"></i>
                    <div style="font-size:13px;">Clique pour ajouter une photo ou vidéo</div>
                </div>
            `
        }

        const storyColors = ["#4f46e5", "#7c3aed", "#db2777", "#dc2626", "#d97706", "#16a34a", "#0891b2", "#0f172a"]
        let selectedColor = storyColors[0]
        let selectedFile = null

        function renderColorPicker() {
            const container = document.getElementById("story-color-picker")
            if (!container) return
            container.innerHTML = ""
            storyColors.forEach(color => {
                const swatch = document.createElement("div")
                swatch.className = "story-color-swatch"
                swatch.style.background = color
                if (color === selectedColor) swatch.classList.add("selected")
                swatch.onclick = () => {
                    selectedColor = color
                    document.querySelectorAll(".story-color-swatch").forEach(s => s.classList.remove("selected"))
                    swatch.classList.add("selected")
                    if (!selectedFile) {
                        document.getElementById("story-preview-area").style.background = color
                    }
                }
                container.appendChild(swatch)
            })
        }

        function handleStoryFileSelect(e) {
            const file = e.target.files[0]
            if (!file) return
            selectedFile = file
            const preview = document.getElementById("story-preview-area")
            const url = URL.createObjectURL(file)
            if (file.type.startsWith("video/")) {
                preview.innerHTML = `<video src="${url}" style="width:100%;height:100%;object-fit:cover;" autoplay muted loop></video>`
            } else {
                preview.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;" alt="">`
            }
            preview.style.background = "none"
        }

        async function publishStory() {
            const texte = document.getElementById("story-text-input").value.trim()
            const btn = document.getElementById("story-publish-btn")
            btn.disabled = true
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Publication...'

            try {
                let res, data
                if (selectedFile) {
                    const formData = new FormData()
                    formData.append("media", selectedFile)
                    if (texte) formData.append("texte", texte)
                    formData.append("couleurFond", selectedColor)
                    res = await fetch("/stories", { method: "POST", body: formData })
                } else if (texte) {
                    res = await fetch("/stories/text", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ texte, couleurFond: selectedColor })
                    })
                } else {
                    alert("Ajoute une image ou un texte.")
                    btn.disabled = false
                    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Publier'
                    return
                }
                data = await res.json()
                if (data.success) {
                    closeStoryCreator()
                    loadStories()
                } else {
                    alert(data.error || "Erreur")
                }
            } catch (e) {
                alert("Erreur de connexion.")
            } finally {
                btn.disabled = false
                btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Publier'
            }
        }

        // Navigation
        document.addEventListener("DOMContentLoaded", function() {
            loadStories()

            // Fermeture overlay
            document.getElementById("story-viewer-close")?.addEventListener("click", closeStoryViewer)
            document.getElementById("story-creator-close")?.addEventListener("click", closeStoryCreator)

            // Navigation clavier
            document.addEventListener("keydown", function(e) {
                if (e.key === "Escape") {
                    closeStoryViewer()
                    closeStoryCreator()
                }
                if (e.key === "ArrowRight") goToNextStory()
                if (e.key === "ArrowLeft") goToPrevStory()
            })
        })

        function toggleComments(postId) {
            const el = document.getElementById('comments-' + postId)
            el.style.display = el.style.display === 'none' ? 'block' : 'none'
        }

        document.getElementById('imageInput').addEventListener('change', function(e) {
            const preview = document.getElementById('imagePreview')
            preview.innerHTML = ''
            const file = e.target.files[0]
            if (file) {
                const img = document.createElement('img')
                img.src = URL.createObjectURL(file)
                img.style.maxWidth = '100%'
                img.style.borderRadius = '10px'
                img.style.maxHeight = '300px'
                preview.appendChild(img)
            }
        })
    </script>

    <!-- ===== OVERLAY STORIES (HTML) ===== -->
    <div class="story-viewer-overlay" id="story-viewer-overlay">
        <div class="story-progress-bar" id="story-progress-container"></div>
        <div class="story-viewer-header">
            <img src="" alt="" id="story-author-avatar">
            <div>
                <div class="story-viewer-author" id="story-author-name"></div>
                <div class="story-viewer-time" id="story-time"></div>
            </div>
            <button class="story-viewer-close" id="story-viewer-close"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="story-viewer-media" id="story-media-container"></div>
        <div class="story-viewer-text-overlay" id="story-text-overlay"></div>
        <div class="story-viewer-nav-prev" onclick="goToPrevStory()"></div>
        <div class="story-viewer-nav-next" onclick="goToNextStory()"></div>
        <div class="story-viewer-footer">
            <div class="story-views-count"><i class="fa-regular fa-eye"></i> <span id="story-views-count">0</span></div>
            <div class="story-emoji-reactions">
                <button class="story-emoji-btn" onclick="reactToStory('❤️')">❤️</button>
                <button class="story-emoji-btn" onclick="reactToStory('😂')">😂</button>
                <button class="story-emoji-btn" onclick="reactToStory('😮')">😮</button>
                <button class="story-emoji-btn" onclick="reactToStory('🔥')">🔥</button>
                <button class="story-emoji-btn" onclick="reactToStory('👏')">👏</button>
            </div>
        </div>
    </div>

    <!-- ===== CREATEUR DE STORY ===== -->
    <div class="story-creator-overlay" id="story-creator-overlay">
        <div class="story-creator-card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                <h3 style="font-size:16px; font-weight:700; color:var(--text-primary);">
                    <i class="fa-solid fa-circle-plus" style="color:var(--primary);"></i> Créer une story
                </h3>
                <button onclick="closeStoryCreator()" style="background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:18px;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="story-creator-preview" id="story-preview-area" onclick="document.getElementById('story-file-input').click()">
                <div style="text-align:center; color:rgba(255,255,255,0.7);">
                    <i class="fa-solid fa-image" style="font-size:32px; margin-bottom:8px; display:block;"></i>
                    <div style="font-size:13px;">Clique pour ajouter une photo ou vidéo</div>
                </div>
            </div>
            <input type="file" id="story-file-input" accept="image/*,video/*" style="display:none" onchange="handleStoryFileSelect(event)">

            <div style="font-size:12px; font-weight:600; color:var(--text-secondary); margin-bottom:6px; margin-top:4px;">
                Couleur de fond
            </div>
            <div class="story-color-picker" id="story-color-picker"></div>

            <div class="form-group" style="margin-bottom:14px;">
                <div class="input-wrapper">
                    <i class="fa-solid fa-pen"></i>
                    <input type="text" id="story-text-input" placeholder="Ajouter un texte (optionnel)" maxlength="200">
                </div>
            </div>

            <div style="display:flex; gap:10px;">
                <button onclick="closeStoryCreator()" class="btn btn-secondary">Annuler</button>
                <button onclick="publishStory()" class="btn" id="story-publish-btn">
                    <i class="fa-solid fa-paper-plane"></i> Publier
                </button>
            </div>
        </div>
    </div>

</body>
</html>
