<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>

    <style>
        /* ===== STORIES BAR ===== */
        .stories-bar {
            display: flex;
            gap: 14px;
            padding: 12px 0 16px;
            overflow-x: auto;
            overflow-y: hidden;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
            border-bottom: 1px solid var(--border, #e5e7eb);
            margin-bottom: 16px;
        }
        .stories-bar::-webkit-scrollbar {
            display: none;
        }

        .story-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            cursor: pointer;
            transition: transform 0.15s;
        }
        .story-item:hover {
            transform: scale(1.04);
        }

        .story-avatar {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            padding: 2px;
            background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .story-avatar.seen {
            background: #d1d5db;
        }
        .story-avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2px solid #fff;
            object-fit: cover;
        }

        .story-name {
            font-size: 11px;
            color: var(--text-secondary, #6b7280);
            max-width: 68px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            text-align: center;
        }

        .story-add-btn {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: var(--primary, #4f46e5);
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 26px;
            border: 2px solid #fff;
            box-shadow: 0 0 0 2px var(--primary, #4f46e5);
            flex-shrink: 0;
            transition: 0.2s;
        }
        .story-add-btn:hover {
            background: var(--primary-dark, #4338ca);
            transform: scale(1.04);
        }
        .story-add-btn span {
            font-size: 10px;
            font-weight: 600;
            margin-top: 2px;
            letter-spacing: 0.3px;
        }

        /* ===== STORY OVERLAY ===== */
        .story-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            z-index: 9999;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .story-overlay.active {
            display: flex;
            opacity: 1;
        }

        .story-progress {
            position: fixed;
            top: 12px;
            left: 16px;
            right: 16px;
            display: flex;
            gap: 4px;
            z-index: 10001;
            padding: 0 4px;
        }
        .story-progress-bar {
            flex: 1;
            height: 3px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 4px;
            overflow: hidden;
        }
        .story-progress-bar .fill {
            height: 100%;
            width: 0%;
            background: #fff;
            border-radius: 4px;
            animation: progressAnim 5s linear forwards;
        }
        @keyframes progressAnim {
            0% { width: 0%; }
            100% { width: 100%; }
        }

        .story-media {
            width: 100%;
            max-width: 420px;
            max-height: 90vh;
            object-fit: contain;
            border-radius: 12px;
            cursor: pointer;
            user-select: none;
        }

        .story-author-info {
            position: fixed;
            top: 32px;
            left: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 10000;
            color: #fff;
            pointer-events: none;
        }
        .story-author-info img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid #fff;
            object-fit: cover;
        }
        .story-author-info span {
            font-weight: 600;
            font-size: 15px;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
        }

        .story-close {
            position: fixed;
            top: 28px;
            right: 20px;
            color: #fff;
            font-size: 28px;
            cursor: pointer;
            z-index: 10001;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7);
            transition: 0.2s;
            pointer-events: auto;
        }
        .story-close:hover {
            transform: scale(1.1);
        }

        .story-views {
            position: fixed;
            bottom: 60px;
            left: 0;
            right: 0;
            text-align: center;
            color: rgba(255, 255, 255, 0.7);
            font-size: 13px;
            font-weight: 400;
            z-index: 10000;
            pointer-events: none;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
        }
        .story-views i {
            margin-right: 6px;
        }

        /* ===== RESPONSIVE STORIES ===== */
        @media (max-width: 480px) {
            .story-avatar { width: 56px; height: 56px; }
            .story-add-btn { width: 56px; height: 56px; font-size: 22px; }
            .story-name { font-size: 10px; max-width: 56px; }
        }
    </style>

</head>
<body>
    <%- include('partials/navbar', { currentPage: 'feed' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'feed' }) %>

        <main class="feed">

            <div class="page-header">
                <div>
                    <h1>Fil d'actualité</h1>
                    <div class="subtitle">Découvre les dernières publications de tes amis</div>
                </div>
            </div>

            <!-- BARRE DE STORIES -->
            <div class="stories-bar" id="storiesBar">
                <div class="story-add-btn" id="addStoryBtn">
                    <i class="fa-solid fa-plus"></i>
                    <span>Ajouter</span>
                </div>
                <input type="file" id="storyInput" accept="image/*" style="display:none">
            </div>

            <!-- OVERLAY STORIES -->
            <div class="story-overlay" id="storyOverlay">
                <div class="story-progress" id="storyProgress"></div>
                <div class="story-close" id="storyClose"><i class="fa-solid fa-xmark"></i></div>
                <div class="story-author-info">
                    <img id="storyAuthorAvatar" src="" alt="">
                    <span id="storyAuthorName"></span>
                </div>
                <img class="story-media" id="storyMedia" src="" alt="">
                <div class="story-views">
                    <i class="fa-regular fa-eye"></i> <span id="storyViewCount">0</span> vues
                </div>
            </div>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- Formulaire de publication -->
            <div class="card post-form">
                <form action="/post" method="POST" enctype="multipart/form-data">
                    <div class="post-form-top">
                        <img src="<%= user.photoProfil %>" class="post-form-avatar" alt="">
                        <textarea name="contenu" placeholder="Quoi de neuf, <%= user.nom.split(' ')[0] %> ?" required></textarea>
                    </div>
                    <div id="imagePreview" style="margin:0 0 10px 56px;"></div>
                    <div class="post-form-footer">
                        <div class="post-form-tools">
                            <label for="imageInput" title="Ajouter une image">
                                <i class="fa-solid fa-image"></i>
                            </label>
                            <input type="file" id="imageInput" name="image" accept="image/*" style="display:none">
                        </div>
                        <button type="submit" class="btn">
                            <i class="fa-solid fa-paper-plane"></i> Publier
                        </button>
                    </div>
                </form>
            </div>

            <!-- Liste des posts -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                    <p>Commence par publier ou ajoute des amis !</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post">
                    <div class="post-header">
                        <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <div class="post-content"><%= post.contenu %></div>

                    <% if (post.image) { %>
                        <img src="<%= post.image %>" class="post-image" alt="">
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">À PROPOS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.6;">
                Bienvenue sur <strong>SocialApp</strong> <i class="fa-solid fa-rocket"></i><br>
                Partage, connecte et discute avec tes amis !
            </p>
        </aside>
    </div>

    <script src="/js/feed.js"></script>
    <script src="/js/stories.js"></script>
    <script>
        function toggleComments(postId) {
            const el = document.getElementById('comments-' + postId)
            el.style.display = el.style.display === 'none' ? 'block' : 'none'
        }

        document.getElementById('imageInput').addEventListener('change', function(e) {
            const preview = document.getElementById('imagePreview')
            preview.innerHTML = ''
            const file = e.target.files[0]
            if (file) {
                const img = document.createElement('img')
                img.src = URL.createObjectURL(file)
                img.style.maxWidth = '100%'
                img.style.borderRadius = '10px'
                img.style.maxHeight = '300px'
                preview.appendChild(img)
            }
        })
    </script>
</body>
</html>
