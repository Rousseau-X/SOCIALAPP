<div class="oracle-quest-card" id="oracleQuestCard">
    <div class="oracle-header">
        <div class="oracle-brand">
            <div class="oracle-icon-wrap">
                <i class="fa-solid fa-brain"></i>
            </div>
            <div>
                <div class="oracle-title">Quête Oracle du jour</div>
                <div class="oracle-subtitle">Mission personnalisée · Expire à minuit</div>
            </div>
        </div>
        <div class="oracle-rewards" id="oracleRewards">
            <span class="oracle-pill oracle-pill-xp"><i class="fa-solid fa-star"></i> <span id="oracleXp">—</span> XP</span>
            <span class="oracle-pill oracle-pill-coins"><i class="fa-solid fa-coins"></i> <span id="oracleCoins">—</span></span>
        </div>
    </div>

    <div class="oracle-body" id="oracleBody">
        <div class="oracle-loading" id="oracleLoading">
            <div class="oracle-spinner"></div>
            <span>Génération de ta quête…</span>
        </div>
        <div id="oracleContent" style="display:none;">
            <p class="oracle-quest-text" id="oracleQuestText"></p>
            <div class="oracle-progress-wrap">
                <div class="oracle-progress-bar">
                    <div class="oracle-progress-fill" id="oracleProgressFill"></div>
                </div>
                <span class="oracle-progress-label" id="oracleProgressLabel">0 / 1</span>
            </div>
            <div class="oracle-footer" id="oracleFooter"></div>
        </div>
    </div>
</div>
